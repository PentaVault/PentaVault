# ============================================================
# PentaVault Root .gitignore
# ============================================================

# Backend — private repo, managed separately, not public yet
PentaVault-Backend/

# Next.js
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files — never commit real values
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Editor
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Testing
coverage/
.nyc_output/

# Misc
*.log
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/
