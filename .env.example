# ============================================================
# PentaVault Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Only NEXT_PUBLIC_* variables are available in the browser.
# ============================================================

# Backend API base URL. Include /api and omit any trailing slash.
# Local:      http://localhost:3001/api
# Production: http://pentavault.abhashchakraborty.tech/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Frontend app URL
# Local:      http://localhost:3000
# Production: http://pentavault.abhashchakraborty.tech
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# UI-only Mock Auth (local development/demo)
# ============================================================
# When enabled, the frontend skips real backend auth calls for sign-in/sign-up
# and uses the mock account values below to open the dashboard UI.
#
# Keep this disabled for normal backend integration.
NEXT_PUBLIC_MOCK_AUTH_ENABLED=false

# Mock account credentials used by login/register in UI-only mode.
NEXT_PUBLIC_MOCK_AUTH_EMAIL=demo@pentavault.local
NEXT_PUBLIC_MOCK_AUTH_PASSWORD=demo-password-123
NEXT_PUBLIC_MOCK_AUTH_NAME=Demo User
NEXT_PUBLIC_MOCK_AUTH_USER_ID=mock-user-1
